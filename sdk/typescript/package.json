{
  "name": "@fletta/sdk",
  "version": "1.1.1",
  "description": "fletta SDK for self-healing test selectors",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./rca": {
      "types": "./dist/rca.d.ts",
      "import": "./dist/rca.js",
      "require": "./dist/rca.js",
      "default": "./dist/rca.js"
    }
  },
  "files": [
    "dist/",
    "wasm/",
    "wasm-node/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kotler-dev/fletta.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://fletta.dev",
  "bugs": {
    "url": "https://github.com/kotler-dev/fletta/issues"
  },
  "scripts": {
    "build:wasm:bundler": "cd ../../crates/core && wasm-pack build --target bundler --out-dir ../../sdk/typescript/wasm --features wasm",
    "build:wasm:node": "cd ../../crates/core && wasm-pack build --target nodejs --out-dir ../../sdk/typescript/wasm-node --features wasm",
    "build:wasm": "npm run build:wasm:bundler && npm run build:wasm:node",
    "build": "npm run build:wasm && tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/ --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "testing",
    "playwright",
    "self-healing",
    "selectors",
    "e2e"
  ],
  "author": "fletta team",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "dependencies": {}
}
